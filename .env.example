# Titan Protocol — mobile-saas environment template.
# Copy to .env and fill in. .env is gitignored.

# === Supabase ===
EXPO_PUBLIC_SUPABASE_URL=https://rmvodrpgaffxeultskst.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<paste anon key from Supabase dashboard or mobile/.env>

# === Google Sign-In (optional; leave empty to hide the Google button) ===
# Create OAuth client IDs at https://console.cloud.google.com/apis/credentials
# - Web Client: used by Supabase to exchange the id_token
# - Android Client: needs SHA-1 from the keystore used to sign the build
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# === Observability (wired in M5) ===
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
