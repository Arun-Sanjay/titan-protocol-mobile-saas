# Titan Protocol — mobile-saas publishable environment variables.
#
# These are safe to commit: every Supabase table is gated by Row-Level
# Security scoped to auth.uid(). The anon key gives anonymous access only
# to public data + the user's own rows once they sign in.
#
# CI (.github/workflows/android-apk.yml) copies this file to .env when
# repo secrets aren't set, so the workflow can build APKs without any
# secret configuration on first run.

# === Supabase ===
EXPO_PUBLIC_SUPABASE_URL=https://rmvodrpgaffxeultskst.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJtdm9kcnBnYWZmeGV1bHRza3N0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU0OTMzMTEsImV4cCI6MjA5MTA2OTMxMX0.O-fsFZzfNSXnRhkHbuvQ0qW2tQUwtiAOwRYP1aQfgC8

# === Google Sign-In (optional; leave empty to hide the Google button) ===
# Create OAuth client IDs at https://console.cloud.google.com/apis/credentials
# - Web Client: used by Supabase to exchange the id_token
# - Android Client: needs SHA-1 from the keystore used to sign the build
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# === Observability (wired in M5) ===
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
